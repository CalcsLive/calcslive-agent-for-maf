    {
      "type": "text",
      "id": "caption",
      "x": 727.4656883222048,
      "y": 585.4011213772218,
      "width": 573.2108944081224,
      "height": 121.53282532239166,
      "text": "Azure AI moderates a human-in-the-loop workflow that turns\nnatural-language requests into reviewed, reusable, unit-\naware CalcsLive calculation assets. \n\nThose assets can then power both cloud/web and desktop/local\nexperiences, with Excel as a flagship integration.",
      "originalText": "Azure AI moderates a human-in-the-loop workflow that turns natural-language requests into reviewed, reusable, unit-aware CalcsLive calculation assets. \n\nThose assets can then power both cloud/web and desktop/local experiences, with Excel as a flagship integration.",
      "fontSize": 16.20437670965222,
      "fontFamily": 3,
      "textAlign": "right",
      "verticalAlign": "top",
      "strokeColor": "#64748b",
      "backgroundColor": "transparent",
