    {
      "type": "text",
      "id": "caption",
      "x": 136.42860172187102,
      "y": 914.8208151321089,
      "width": 1200,
      "height": 40,
      "text": "Azure AI moderates a human-in-the-loop workflow that turns natural-language requests into reviewed, reusable, unit-aware CalcsLive\ncalculation assets. Those assets can then power both cloud/web and desktop/local experiences, with Excel as a flagship integration.",
      "originalText": "Azure AI moderates a human-in-the-loop workflow that turns natural-language requests into reviewed, reusable, unit-aware CalcsLive\ncalculation assets. Those assets can then power both cloud/web and desktop/local experiences, with Excel as a flagship integration.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
